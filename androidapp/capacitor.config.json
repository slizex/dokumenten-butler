{
  "appId": "de.slizex.dokumentenbutler",
  "appName": "Dokumenten-Butler",
  "webDir": "www",
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 800,
      "backgroundColor": "#1d4ed8",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#1d4ed8"
    }
  }
}
